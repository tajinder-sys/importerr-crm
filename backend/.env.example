PORT=5000
MONGODB_URI=mongodb://localhost:27017/crm_system
JWT_SECRET=your_super_secret_jwt_key_here
NODE_ENV=development
IMPORTERR_BASE_URL=https://api.your-importerr.com
IMPORTERR_TIMEOUT_MS=15000
WHATSAPP_API_URL=https://api.whatsapp-provider.com/messages
WHATSAPP_API_TOKEN=your_whatsapp_api_token
WHATSAPP_FROM=your_whatsapp_sender_id
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_API_URL=https://api.sendgrid.com/v3/mail/send
INTERNAL_SERVICE_NAME=crm
INTERNAL_SERVICE_API_KEY=shared_secret_between_crm_and_importerr
INTERNAL_JWT_SECRET=shared_jwt_secret_between_crm_and_importerr
INTERNAL_JWT_EXPIRY=15m
IMPORTERR_TIMEOUT_MS=15000
INTERNAL_SERVICE_ENABLED=true
INTERNAL_JWT_TOKEN_CACHE_TTL=900
IMPORTERR_TOKEN_CACHE_KEY=internal:token:importerr
# Upstash (recommended): copy "Redis URL" from dashboard — use rediss:// (TLS)
# REDIS_URL=rediss://default:YOUR_PASSWORD@YOUR-ENDPOINT.upstash.io:6379
# Local Redis:
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
